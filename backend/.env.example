# Application
APP_NAME="English Learning Platform"
APP_VERSION="1.0.0"
DEBUG=False

# Database
# Для SQLite:
DATABASE_URL=sqlite:///./english_learning.db

# Для PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/english_learning_db

# Security
SECRET_KEY=your-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000", "https://your-frontend-domain.vercel.app"]

# API
API_V1_PREFIX=/api/v1
